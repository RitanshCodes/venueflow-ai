{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run CLI Goal",
      "type": "python",
      "request": "launch",
      "module": "app.cli",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "args": [
        "--goal",
        "Design a go-to-market plan for an AI research assistant for law firms"
      ]
    },
    {
      "name": "Run FastAPI Server",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "args": [
        "app.main:app",
        "--reload",
        "--app-dir",
        "."
      ]
    }
  ]
}
